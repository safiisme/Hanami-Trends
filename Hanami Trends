        <circle cx="0" cy="0" r="1.1" fill="#F0D070"/>
      </g>
    </svg>
    <div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600;color:#C9A84C;letter-spacing:0.1em;">HANAMI</div>
      <div style="font-size:8px;letter-spacing:0.35em;color:rgba(201,168,76,0.5);text-transform:uppercase;margin-top:-2px;">TRENDS</div>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#shop">Collection</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <button class="nav-cta">Shop Now</button>
</nav>

<!-- HERO -->
<section id="home">
  <div class="bg-lines" id="bgLines"></div>

  <!-- Big crane watermark -->
  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0.04;">
    <svg width="700" height="700" viewBox="0 0 130 150">
      <defs>
        <linearGradient id="hG1" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#F5E090"/>
          <stop offset="100%" stop-color="#C9A84C"/>
        </linearGradient>
      </defs>
